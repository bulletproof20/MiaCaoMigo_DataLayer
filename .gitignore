# =========================================================
# NODE.JS DEPENDENCIES
# =========================================================
# Installed package dependencies generated locally by npm,
# pnpm or yarn package managers.
# =========================================================
node_modules/

# =========================================================
# ENVIRONMENT / SECRET CONFIGURATION
# =========================================================
# Local environment variables and developer-specific
# runtime configuration.
# =========================================================
.env

# =========================================================
# VISUAL STUDIO CODE CONFIGURATION
# =========================================================
# Local editor preferences, workspace settings and
# machine-specific VS Code metadata.
# =========================================================
.vscode/

# =========================================================
# PERSONAL WORKSPACE FILES
# =========================================================
# User-specific workspace aggregation files.
# =========================================================
MiaCaoMigo_website.code-workspace

# =========================================================
# OPERATING SYSTEM METADATA
# =========================================================
# Hidden files automatically generated by Windows and macOS.
# =========================================================
.DS_Store
desktop.ini
Thumbs.db

# =========================================================
# PACKAGE MANAGER / RUNTIME LOGS
# =========================================================
# Runtime failure logs and package manager debug traces.
# =========================================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =========================================================
# BUILD OUTPUT / CACHE ARTIFACTS
# =========================================================
# Generated build artifacts, cache layers and temporary
# compilation outputs.
# =========================================================
dist/
build/
.cache/