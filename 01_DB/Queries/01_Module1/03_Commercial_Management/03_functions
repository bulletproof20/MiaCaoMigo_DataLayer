-- is_user_logged_in(id_usr)
-- Checks if user currently has an active session


CREATE OR REPLACE FUNCTION is_user_logged_in(p_id_usr INT) 
RETURNS BOOLEAN AS $$
    SELECT EXISTS (
        SELECT 1 FROM performs p 
        JOIN login_record l 
            ON p.id_log = l.id_log 
            
        WHERE p.id_usr = p_id_usr 
          AND l.sou_tim_log IS NULL 
          AND l.suc_log = TRUE
          AND l.sig_tim_log > NOW() - INTERVAL '2 hours'  
    ); 
$$ LANGUAGE sql;
GRANT EXECUTE ON FUNCTION is_user_logged_in TO anon;



-- get_active_session(id_usr)
-- Retrieves active login session

-- get_active_sessions()
-- Retrieves all active sessions
CREATE OR REPLACE FUNCTION get_active_sessions() 
RETURNS TABLE(id_usr INT, name VARCHAR, login_time TIMESTAMP, ip VARCHAR) AS $$
    SELECT 
        u.id_usr, 
        u.nam_usr, 
        l.sig_tim_log, 
        l.ip_add_log 

    FROM user_account u JOIN performs p ON u.id_usr = p.id_usr
    JOIN login_record l ON p.id_log = l.id_log
    
    WHERE l.sou_tim_log IS NULL 
      AND l.suc_log = TRUE
      AND l.sig_tim_log > NOW() - INTERVAL '2 hours';   
$$ LANGUAGE sql;
GRANT EXECUTE ON FUNCTION get_active_sessions TO anon;


