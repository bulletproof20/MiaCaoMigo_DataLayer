-- get_last_login(id_usr)
-- Retrieves last login attempt
CREATE OR REPLACE FUNCTION get_last_login(p_id_usr INT) 
RETURNS SETOF login_record AS $$
    SELECT 
    l.* 
    FROM login_record l JOIN performs p ON l.id_log = p.id_log
    WHERE p.id_usr = p_id_usr ORDER BY l.sig_tim_log DESC LIMIT 1;
$$ LANGUAGE sql;

GRANT EXECUTE ON FUNCTION get_last_login TO anon;



-- get_last_successful_login(id_usr)
-- Retrieves last successful login
CREATE OR REPLACE FUNCTION get_last_successful_login(p_id_usr INT) 
RETURNS SETOF login_record AS $$
    SELECT l.* FROM login_record l
    JOIN performs p ON l.id_log = p.id_log
    WHERE p.id_usr = p_id_usr AND l.suc_log = TRUE
    ORDER BY l.sig_tim_log DESC LIMIT 1;
$$ LANGUAGE sql;
GRANT EXECUTE ON FUNCTION get_last_successful_login TO anon;



-- get_last_failed_login(id_usr)
-- Retrieves last failed login
CREATE OR REPLACE FUNCTION get_last_failed_login(p_id_usr INT) 
RETURNS SETOF login_record AS $$
    SELECT 
    l.* 
    FROM login_record l
    JOIN performs p ON l.id_log = p.id_log
    WHERE p.id_usr = p_id_usr AND l.suc_log = FALSE
    ORDER BY l.sig_tim_log DESC LIMIT 1;
$$ LANGUAGE sql;
GRANT EXECUTE ON FUNCTION get_last_failed_login TO anon;




-- get_user_by_email(email)

CREATE OR REPLACE FUNCTION get_user_by_email(p_email VARCHAR) 
RETURNS INT AS $$
