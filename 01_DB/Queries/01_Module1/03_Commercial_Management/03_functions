-- get_user_credentials(id_usr)
-- Retrieves authentication-related data
CREATE OR REPLACE FUNCTION get_user_credentials(p_id_usr INT) 
RETURNS TABLE(id_usr INT, email VARCHAR, pass_hash VARCHAR, role TEXT) AS $$
    -- Prioridade: se for employee, retorna employee (mesmo que também seja client)
    SELECT 
    u.id_usr, 
    u.ema_usr, 
    e.pas_emp, 'employee'
    FROM user_account u JOIN employee e ON u.id_usr = e.id_usr

    WHERE u.id_usr = p_id_usr
    
    UNION  -- NOT ALL: elimina duplicados (embora não devam existir)
    
    -- Só retorna client se NÃO for employee
    SELECT 
    u.id_usr, 
    u.ema_usr, 
    c.pas_cli, 'client'

    FROM user_account u JOIN client c ON u.id_usr = c.id_usr
    WHERE u.id_usr = p_id_usr
      AND NOT EXISTS (SELECT 1 FROM employee WHERE id_usr = p_id_usr);
$$ LANGUAGE sql;
GRANT EXECUTE ON FUNCTION get_user_credentials TO anon;





